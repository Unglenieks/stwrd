{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["./_generated", "./**/*.test.ts"]
}

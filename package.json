{
  "name": "stwrd",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hostable custody-based community lending — Stwrd.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck && tsc -p convex/tsconfig.json --noEmit",
    "test": "pnpm -r test && pnpm test:convex",
    "test:convex": "vitest run --config vitest.convex.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.80",
    "@stwrd/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "convex": "^1.17.0",
    "imapflow": "^1.0.171",
    "nodemailer": "^6.9.16",
    "otpauth": "^9.3.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "convex-test": "^0.0.35",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

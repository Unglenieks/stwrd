# Stwrd — production environment (spec §19.3).
# Copy to `.env`, fill in the required values, then `docker compose up -d`.
# `.env` is gitignored — never commit real secrets.

# ── Public origin (single source of truth) ───────────────────────────────────
# The HTTPS URL your users reach. Everything derives from this.
SITE_ORIGIN=https://library.example.org

# Convex client API origin — always SITE_ORIGIN + /api.
# Caddy strips the /api prefix and routes to the backend on :3210.
CONVEX_CLOUD_ORIGIN=https://library.example.org/api

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Hostname Caddy serves TLS for (just the hostname, no scheme).
PROXY_HOSTNAME=library.example.org
# Let's Encrypt contact email for certificate expiry notices.
ACME_EMAIL=admin@example.org

# ── Convex backend identity ───────────────────────────────────────────────────
# Generate strong random values:
#   INSTANCE_NAME:   openssl rand -hex 6
#   INSTANCE_SECRET: openssl rand -hex 32
INSTANCE_NAME=replace-with-openssl-rand-hex-6
INSTANCE_SECRET=replace-with-openssl-rand-hex-32

# External Postgres for larger installs. Leave empty to use SQLite (default).
POSTGRES_URL=

# ── Organisation ──────────────────────────────────────────────────────────────
ORG_NAME=My Library

# ── Server manager credentials (optional) ────────────────────────────────────
# If left blank:
#   - Email defaults to admin@<hostname>
#   - A strong random password is generated, printed to bootstrap logs,
#     and written to deploy/secrets/server-manager-credentials.txt
#
# In production, leave SERVER_MANAGER_PASSWORD blank so the password is
# randomly generated, then reset it after first login (see docs/first-run.md).
SERVER_MANAGER_EMAIL=
SERVER_MANAGER_PASSWORD=

# ── Misc ──────────────────────────────────────────────────────────────────────
REDACT_LOGS_TO_CLIENT=true

# Distributed Library of Things — environment contract (spec §19.3).
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# ── Public hostname (single source of truth, §19.5) ──────────────────────────
# All absolute URLs in outbound email derive from PUBLIC_SITE_ORIGIN. There is
# no second, independently editable base-URL field. Changing these + restart is
# the entire domain-change runbook (§19.5).
PUBLIC_SITE_ORIGIN=https://library.example.org
PUBLIC_API_ORIGIN=https://library.example.org/api

# Convex HTTP-actions (site) origin — where /.well-known/jwks.json and the
# /auth/* endpoints live. The backend resolves its own JWT issuer + JWKS from
# this URL, and the browser calls /auth/* here. It must route to the backend's
# :3211 port and is DISTINCT from the public frontend origin above. In a proxied
# deployment, give it its own hostname/path (e.g. https://api.library.example.org).
CONVEX_SITE_ORIGIN=https://api.library.example.org

# Browser-facing Convex HTTP-actions origin, baked into /runtime-config.json for
# the frontend (§19.5). Usually identical to CONVEX_SITE_ORIGIN; separate only
# when the backend reaches its site origin by a different (internal) URL than the
# browser does.
PUBLIC_CONVEX_SITE_ORIGIN=https://api.library.example.org

# ── Convex backend identity & secrets ────────────────────────────────────────
# Generate strong random values, e.g.:
#   INSTANCE_NAME:   openssl rand -hex 6        (lowercase letters/digits)
#   INSTANCE_SECRET: openssl rand -hex 32
INSTANCE_NAME=changeme-instance
INSTANCE_SECRET=replace-with-openssl-rand-hex-32

# Optional external Postgres for larger installs. Empty ⇒ SQLite (default).
#   POSTGRES_URL=postgres://user:pass@host:5432/convex
POSTGRES_URL=

# ── Function-side secret (Convex deployment env var, NOT a container env) ─────
# APP_SECRETS_KEY encrypts SMTP/IMAP credentials and TOTP secrets at rest (§18.1,
# §19.1). It is set on the BACKEND via `npx convex env set APP_SECRETS_KEY <val>`,
# never baked into the frontend. Generate: openssl rand -base64 32
# (Listed here only as a reminder; do not put it in the frontend container.)
# APP_SECRETS_KEY=replace-with-openssl-rand-base64-32

# ── Proxy ────────────────────────────────────────────────────────────────────
# The hostname Caddy serves. For ACME HTTP-01, ports 80/443 must be reachable.
PROXY_HOSTNAME=library.example.org
# ACME contact email for Let's Encrypt notifications.
ACME_EMAIL=admin@example.org
